# CervixAI Backend - Configuración de Ejemplo
# Copia este archivo como .env.local para usar en desarrollo

# Puerto del servidor backend
PORT=4000

# Clave secreta para JWT (cambiar en producción)
JWT_SECRET=cervix-ai-secret-change-in-production

# Ambiente
NODE_ENV=development

# Base de datos
DATABASE_PATH=./data/cervixai.db

# Logging
LOG_LEVEL=info

# CORS
CORS_ORIGIN=http://localhost:4200

# Entrenamiento del modelo
MODEL_PATH=./models/model.json
TRAINING_DATA_PATH=./data/training-data.json
